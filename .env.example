# =========================================================
# Spring Profile Selection
# =========================================================
# local | dev | prod
SPRING_PROFILES_ACTIVE=local

# =========================================================
# Local Profile Variables (application-local.yml)
# =========================================================
LOCAL_JWT_SECRET=change-this-local-jwt-secret-minimum-32-characters
LOCAL_MONGODB_URI=mongodb://localhost:27017/manud-jaya
LOCAL_SUPABASE_URL=https://your-local-supabase-project.supabase.co
LOCAL_SUPABASE_API_KEY=local-api-key
LOCAL_SUPABASE_BUCKET=Object-Image
LOCAL_S3_ENDPOINT=https://your-local-supabase-project.storage.supabase.co/storage/v1/s3
LOCAL_S3_ACCESS_KEY=local-access-key
LOCAL_S3_SECRET_KEY=local-secret-key

# =========================================================
# Development Profile Variables (application-dev.yml)
# =========================================================
DEV_JWT_SECRET=dev-jwt-secret-minimum-32-characters
# Same cluster, different DB name for dev
DEV_MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.lkpsu9n.mongodb.net/manud-jaya-dev?retryWrites=true&w=majority&authSource=admin
# Same Supabase project URL/key, different bucket for dev
DEV_SUPABASE_URL=https://kvnsbatzpsbrocyinnpy.supabase.co
DEV_SUPABASE_API_KEY=<dev-api-key>
DEV_SUPABASE_BUCKET=Object-Image-Dev
DEV_S3_ENDPOINT=https://kvnsbatzpsbrocyinnpy.storage.supabase.co/storage/v1/s3
DEV_S3_ACCESS_KEY=<dev-access-key>
DEV_S3_SECRET_KEY=<dev-secret-key>

# =========================================================
# Production Profile Variables (application-prod.yml)
# =========================================================
PROD_JWT_SECRET=prod-jwt-secret-minimum-32-characters
# Same cluster, different DB name for prod
PROD_MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.lkpsu9n.mongodb.net/manud-jaya?retryWrites=true&w=majority&authSource=admin
# Same Supabase project URL/key, different bucket for prod
PROD_SUPABASE_URL=https://kvnsbatzpsbrocyinnpy.supabase.co
PROD_SUPABASE_API_KEY=<prod-api-key>
PROD_SUPABASE_BUCKET=Object-Image
PROD_S3_ENDPOINT=https://kvnsbatzpsbrocyinnpy.storage.supabase.co/storage/v1/s3
PROD_S3_ACCESS_KEY=<prod-access-key>
PROD_S3_SECRET_KEY=<prod-secret-key>
